# ============================================================
# Environment Variables - Copy to .env and fill in values
# ============================================================

# ---- Application ----
APP_NAME=MisinformationDetector
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/misinformation_db
MONGODB_URL=mongodb://localhost:27017/misinformation_db
REDIS_URL=redis://localhost:6379/0

# ---- Vector Database ----
CHROMA_PERSIST_DIR=./data/chroma_db

# ---- Hugging Face ----
HUGGINGFACE_TOKEN=your-hf-token-here

# ---- Groq LLM ----
GROQ_API_KEY=your-groq-api-key-here

# ---- Weights & Biases ----
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=misinformation-detector

# ---- MLflow ----
MLFLOW_TRACKING_URI=./mlruns

# ---- Optional API Keys (for data collection) ----
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
NEWS_API_KEY=

# ---- Model Paths ----
TEXT_MODEL_PATH=./models/text_classifier
IMAGE_MODEL_PATH=./models/image_classifier
VIDEO_MODEL_PATH=./models/video_classifier
ENSEMBLE_MODEL_PATH=./models/ensemble

# ---- Processing ----
MAX_TEXT_LENGTH=512
MAX_IMAGE_SIZE=1024
BATCH_SIZE=32
NUM_WORKERS=4

# ---- API Settings ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ---- Monitoring ----
PROMETHEUS_PORT=9090
SENTRY_DSN=
